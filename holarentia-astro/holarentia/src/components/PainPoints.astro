---
// PainPoints.astro
const pains = [
  {
    emoji: '🧳',
    title: 'Vives lejos y no puedes entregar llaves ni revisar limpiezas.',
    tag: 'Propietario remoto',
  },
  {
    emoji: '💸',
    title: 'Quieres el 100% de tus ingresos y odias pagar comisiones del 20–30%.',
    tag: 'Comisiones abusivas',
  },
  {
    emoji: '📲',
    title: 'Estás cansado de responder mensajes a las 11 de la noche.',
    tag: 'Sin descanso',
  },
  {
    emoji: '🧹',
    title: 'Quieres calidad, pero no tienes tiempo para coordinar limpiadoras.',
    tag: 'Gestión agotadora',
  },
];
---

<section id="propietarios" class="py-24 px-5 bg-brand-deep/40">
  <div class="max-w-5xl mx-auto">

    <!-- Header -->
    <div class="text-center mb-14">
      <span class="inline-block text-xs text-brand-coral uppercase tracking-[0.2em] font-semibold mb-4">Para propietarios</span>
      <h2 class="font-display font-bold text-4xl md:text-5xl text-white leading-tight">
        ¿Te reconoces en <br class="hidden sm:block"/>alguno de estos casos?
      </h2>
    </div>

    <!-- Pain cards -->
    <div class="grid sm:grid-cols-2 gap-5">
      {pains.map((p, i) => (
        <div
          class="group flex gap-5 items-start bg-brand-card border border-brand-border hover:border-brand-coral/40 rounded-2xl p-6 transition-all duration-300 hover:bg-brand-card/80"
        >
          <div class="text-4xl flex-shrink-0 group-hover:scale-110 transition-transform duration-300">
            {p.emoji}
          </div>
          <div>
            <span class="inline-block text-xs bg-brand-coral/10 text-brand-coral px-2 py-0.5 rounded-full mb-2 font-semibold">
              {p.tag}
            </span>
            <p class="text-white font-medium leading-snug text-lg">
              {p.title}
            </p>
          </div>
        </div>
      ))}
    </div>

    <!-- Resolution callout -->
    <div class="mt-10 text-center bg-gradient-to-r from-brand-coral/10 via-brand-coral/5 to-brand-coral/10 border border-brand-coral/20 rounded-3xl p-8">
      <p class="text-2xl font-display font-bold text-white mb-3">
        Hola Rentia resuelve todo esto.
      </p>
      <p class="text-brand-muted mb-6 max-w-lg mx-auto">
        Tarifa fija mensual. Tú cobras directamente de Airbnb.
        Nosotros gestionamos el resto.
      </p>
      <a
        href="#precios"
        class="inline-flex items-center gap-2 bg-brand-coral hover:bg-orange-500 text-white font-bold px-8 py-4 rounded-2xl transition-all duration-300 hover:shadow-[0_0_30px_rgba(255,84,54,0.4)] hover:-translate-y-0.5"
      >
        Ver planes y precios →
      </a>
    </div>
  </div>
</section>
