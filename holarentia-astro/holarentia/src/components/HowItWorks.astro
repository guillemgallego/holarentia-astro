---
// HowItWorks.astro
const steps = [
  {
    number: '①',
    emoji: '🛠️',
    title: 'Configuramos tu propiedad',
    subtitle: 'Ajustamos tu anuncio para ganar más desde el primer día.',
    items: [
      'Optimizamos fotos y textos para máxima conversión',
      'Rediseñamos tu anuncio completo',
      'Activamos nuestra IA de precios inteligentes',
    ],
    color: 'from-brand-coral/20 to-brand-coral/5',
    accent: 'border-brand-coral/40',
  },
  {
    number: '②',
    emoji: '🤖',
    title: 'Automatizamos todo',
    subtitle: 'Tu Airbnb funcionando en piloto automático.',
    items: [
      'Mensajes automáticos a huéspedes 24/7',
      'Filtrado inteligente anti-fiestas',
      'Sincronización de calendarios sin overbooking',
    ],
    color: 'from-blue-600/20 to-blue-600/5',
    accent: 'border-blue-500/40',
  },
  {
    number: '③',
    emoji: '🧹',
    title: 'Logística resuelta (Plan 360)',
    subtitle: 'Delegación total con equipo local supervisado por nosotros.',
    items: [
      'Coordinación de limpieza tras cada salida',
      'Gestión de mantenimiento y reparaciones',
      'Control de inventario y check-in sin moverte',
    ],
    color: 'from-emerald-600/20 to-emerald-600/5',
    accent: 'border-emerald-500/40',
  },
];
---

<section id="funciona" class="py-24 px-5">
  <div class="max-w-6xl mx-auto">

    <!-- Header -->
    <div class="text-center mb-16">
      <span class="inline-block text-xs text-brand-coral uppercase tracking-[0.2em] font-semibold mb-4">Cómo funciona</span>
      <h2 class="font-display font-bold text-4xl md:text-5xl text-white leading-tight">
        ¿Por qué elegir Hola <em class="not-italic text-brand-coral">Rent<span>IA</span></em>?
      </h2>
      <p class="mt-4 text-brand-muted text-lg max-w-2xl mx-auto">
        Trabajamos con un modelo híbrido: <strong class="text-white">IA + equipo local</strong>.
        Tú decides cuánto delegar con nuestros dos niveles de servicio.
      </p>
    </div>

    <!-- Steps grid -->
    <div class="grid md:grid-cols-3 gap-6">
      {steps.map((step, i) => (
        <article
          class={`relative bg-gradient-to-b ${step.color} border ${step.accent} rounded-3xl p-8 hover:-translate-y-2 transition-transform duration-300 bg-brand-card`}
          style={`animation-delay:${i*0.1}s`}
        >
          <!-- Number -->
          <div class="font-display font-extrabold text-5xl text-white/10 absolute top-6 right-6 leading-none select-none">
            {step.number}
          </div>

          <div class="text-4xl mb-5">{step.emoji}</div>

          <h3 class="font-display font-bold text-xl text-white mb-2">{step.title}</h3>
          <p class="text-brand-muted text-sm mb-6 italic">{step.subtitle}</p>

          <ul class="space-y-3">
            {step.items.map(item => (
              <li class="flex items-start gap-3 text-sm text-brand-light/80">
                <span class="mt-1 w-4 h-4 rounded-full bg-brand-coral/20 flex-shrink-0 flex items-center justify-center">
                  <svg class="w-2.5 h-2.5 text-brand-coral" fill="currentColor" viewBox="0 0 8 8">
                    <path d="M6.41 1.41L3 4.83 1.59 3.42 0 5l3 3 5-5z"/>
                  </svg>
                </span>
                {item}
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>
