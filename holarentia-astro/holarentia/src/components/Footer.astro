---
// Footer.astro
const legal = [
  { label: 'Términos y Condiciones', href: '/terminos-y-condiciones/' },
  { label: 'Reembolsos',             href: '/reembolsos/' },
  { label: 'Cookies',                href: '/cookies/' },
  { label: 'Aviso Legal',            href: '/aviso-legal/' },
];

const countries = ['Panamá', 'España', 'México', 'Costa Rica', 'Colombia', 'Portugal', 'EE.UU.', '+20 países más'];
---

<footer class="bg-brand-deep border-t border-brand-border pt-16 pb-8 px-5">
  <div class="max-w-6xl mx-auto">

    <div class="grid md:grid-cols-3 gap-10 mb-12">

      <!-- Brand -->
      <div>
        <a href="/" class="flex items-center gap-2 mb-4" aria-label="Hola Rentia">
          <div class="w-9 h-9 rounded-xl bg-brand-coral flex items-center justify-center font-display font-bold text-white text-lg">H</div>
          <span class="font-display font-bold text-xl text-white">
            Hola <span class="text-brand-coral">Rent<em class="not-italic">IA</em></span>
          </span>
        </a>
        <p class="text-brand-muted text-sm leading-relaxed mb-5">
          Automatización Airbnb global con IA.<br/>
          0% comisiones · Pagos directos a tu cuenta.<br/>
          IA + Equipo humano real.
        </p>
        <!-- Trust badges text -->
        <div class="flex flex-wrap gap-2">
          {['✔ 0% comisiones', '✔ Sin permanencia', '✔ Garantía 30 días'].map(b => (
            <span class="text-xs bg-brand-card border border-brand-border text-brand-muted px-3 py-1 rounded-full">{b}</span>
          ))}
        </div>
      </div>

      <!-- Countries -->
      <div>
        <h3 class="font-display font-bold text-white text-sm uppercase tracking-widest mb-4">Tecnología Global</h3>
        <div class="flex flex-wrap gap-2">
          {countries.map(c => (
            <span class="text-xs text-brand-muted bg-brand-card border border-brand-border px-3 py-1 rounded-full">{c}</span>
          ))}
        </div>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="font-display font-bold text-white text-sm uppercase tracking-widest mb-4">¿Hablamos?</h3>
        <div class="space-y-3">
          <a
            href="mailto:hola@holarentia.com"
            class="flex items-center gap-3 text-brand-muted hover:text-white transition-colors text-sm group"
          >
            <span class="w-8 h-8 rounded-lg bg-brand-card border border-brand-border flex items-center justify-center group-hover:border-brand-coral/40 transition-colors">
              📧
            </span>
            hola@holarentia.com
          </a>
          <a
            href="https://wa.me/34642017089"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-3 text-brand-muted hover:text-white transition-colors text-sm group"
          >
            <span class="w-8 h-8 rounded-lg bg-brand-card border border-brand-border flex items-center justify-center group-hover:border-brand-coral/40 transition-colors">
              💬
            </span>
            WhatsApp · Respuesta &lt;2h
          </a>
        </div>

        <a
          href="/empezar/"
          class="mt-6 inline-flex items-center gap-2 bg-brand-coral hover:bg-orange-500 text-white text-sm font-bold px-5 py-3 rounded-xl transition-all duration-200 hover:shadow-[0_0_20px_rgba(255,84,54,0.3)]"
        >
          🔍 Análisis gratuito
        </a>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-brand-border pt-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-brand-muted">
      <p>© {new Date().getFullYear()} Hola Rentia. Powered by AI. Spreading Love & Freedom ❤️</p>
      <nav class="flex flex-wrap justify-center gap-x-5 gap-y-2" aria-label="Legal">
        {legal.map(l => (
          <a href={l.href} class="hover:text-white transition-colors">{l.label}</a>
        ))}
      </nav>
    </div>
  </div>
</footer>
