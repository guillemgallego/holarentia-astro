---
// Hero.astro
---

<section class="relative min-h-screen flex items-center pt-24 pb-16 overflow-hidden">

  <!-- Background glow -->
  <div class="absolute inset-0 bg-hero-glow pointer-events-none" aria-hidden="true"></div>

  <!-- Decorative grid pattern -->
  <div
    class="absolute inset-0 opacity-[0.04] pointer-events-none"
    style="background-image: linear-gradient(rgba(255,255,255,.6) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.6) 1px, transparent 1px); background-size: 48px 48px;"
    aria-hidden="true"
  ></div>

  <!-- Floating orbs -->
  <div class="absolute top-1/4 right-10 w-72 h-72 rounded-full bg-brand-coral/5 blur-3xl animate-pulse-slow pointer-events-none" aria-hidden="true"></div>
  <div class="absolute bottom-1/4 left-5 w-96 h-96 rounded-full bg-blue-600/5 blur-3xl animate-pulse-slow pointer-events-none" style="animation-delay:1.5s" aria-hidden="true"></div>

  <div class="relative max-w-6xl mx-auto px-5 grid lg:grid-cols-2 gap-12 items-center">

    <!-- Copy -->
    <div class="space-y-8">

      <!-- Badge -->
      <div class="inline-flex items-center gap-2 bg-brand-coral/10 border border-brand-coral/30 text-brand-coral text-xs font-semibold px-4 py-2 rounded-full animate-fade-in">
        <span class="w-2 h-2 rounded-full bg-brand-coral animate-pulse inline-block"></span>
        Disponible en España y +20 países · Sin permanencia
      </div>

      <!-- Headline -->
      <h1 class="font-display font-extrabold text-5xl md:text-6xl xl:text-7xl leading-[1.05] text-white animate-fade-up" style="animation-delay:0.1s;opacity:0">
        Gestión Airbnb<br />
        con <em class="not-italic text-brand-coral">IA</em>.<br />
        <span class="text-brand-muted text-4xl md:text-5xl xl:text-6xl font-semibold">Cero comisiones.</span>
      </h1>

      <!-- Subheadline -->
      <p class="text-lg text-brand-muted leading-relaxed max-w-lg animate-fade-up" style="animation-delay:0.25s;opacity:0">
        Quédate con el <strong class="text-white font-semibold">100% de tus ingresos</strong>.
        Nosotros gestionamos la tecnología, los huéspedes y la logística diaria
        por una <strong class="text-white font-semibold">tarifa mensual fija desde €99</strong>.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4 animate-fade-up" style="animation-delay:0.4s;opacity:0">
        <a
          href="#precios"
          class="inline-flex items-center justify-center gap-2 bg-brand-coral hover:bg-orange-500 text-white font-bold px-8 py-4 rounded-2xl text-lg transition-all duration-300 hover:shadow-[0_0_30px_rgba(255,84,54,0.45)] hover:-translate-y-1 active:scale-95"
        >
          🔥 Empieza a ganar más hoy
        </a>
        <a
          href="#funciona"
          class="inline-flex items-center justify-center gap-2 bg-brand-card border border-brand-border text-white font-semibold px-8 py-4 rounded-2xl text-lg hover:border-brand-coral/50 transition-all duration-300 hover:-translate-y-1"
        >
          Cómo funciona →
        </a>
      </div>

      <!-- Social proof micro -->
      <div class="flex items-center gap-4 animate-fade-up" style="animation-delay:0.55s;opacity:0">
        <!-- Avatar stack -->
        <div class="flex -space-x-3">
          {['bg-pink-500','bg-indigo-500','bg-emerald-500','bg-amber-500'].map((c, i) => (
            <div class={`w-9 h-9 rounded-full ${c} border-2 border-brand-navy flex items-center justify-center text-white text-xs font-bold`}>
              {['SJ','MT','SL','MR'][i]}
            </div>
          ))}
        </div>
        <div class="text-sm text-brand-muted">
          <span class="text-white font-semibold">+500 propietarios</span> ya ahorran
          <span class="text-brand-coral font-semibold">€401/mes</span> de media
        </div>
      </div>
    </div>

    <!-- Visual card -->
    <div class="relative animate-fade-in" style="animation-delay:0.3s;opacity:0">

      <!-- Dashboard mockup card -->
      <div class="relative bg-brand-card border border-brand-border rounded-3xl p-6 shadow-2xl shadow-black/50">

        <!-- Card header -->
        <div class="flex items-center justify-between mb-6">
          <div>
            <p class="text-xs text-brand-muted uppercase tracking-widest">Ingresos este mes</p>
            <p class="font-display font-bold text-4xl text-white mt-1">€3,247 <span class="text-brand-coral text-lg font-semibold">+24%</span></p>
          </div>
          <div class="w-12 h-12 rounded-2xl bg-brand-coral/15 flex items-center justify-center">
            <svg class="w-6 h-6 text-brand-coral" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
            </svg>
          </div>
        </div>

        <!-- Mini bar chart -->
        <div class="flex items-end gap-1.5 h-20 mb-6">
          {[40,60,45,75,55,85,90,70,95,80,88,100].map((h, i) => (
            <div
              class="flex-1 rounded-t-sm transition-all"
              style={`height:${h}%;background:${i===11?'#FF5436':'rgba(255,84,54,0.25)'};animation:fadeUp 0.4s ease ${i*0.05}s both`}
            ></div>
          ))}
        </div>

        <!-- Stats row -->
        <div class="grid grid-cols-3 gap-3">
          {[
            { label: 'Ocupación',   val: '87%',    icon: '📅' },
            { label: 'Valoración',  val: '4.9 ⭐',  icon: '🏆' },
            { label: 'Ahorro/mes',  val: '€401',   icon: '💰' },
          ].map(stat => (
            <div class="bg-brand-deep rounded-xl p-3 text-center">
              <p class="text-xl mb-1">{stat.icon}</p>
              <p class="font-display font-bold text-white text-lg">{stat.val}</p>
              <p class="text-xs text-brand-muted">{stat.label}</p>
            </div>
          ))}
        </div>

        <!-- IA badge -->
        <div class="mt-4 flex items-center gap-2 bg-brand-coral/10 border border-brand-coral/20 rounded-xl px-4 py-2.5">
          <div class="w-2 h-2 rounded-full bg-brand-coral animate-pulse"></div>
          <p class="text-sm text-brand-coral font-medium">IA activa · Optimizando precios en tiempo real</p>
        </div>
      </div>

      <!-- Floating notification -->
      <div class="absolute -top-5 -right-4 bg-white text-gray-900 rounded-2xl shadow-xl px-4 py-3 text-sm font-semibold flex items-center gap-2 animate-bounce" style="animation-duration:3s">
        🎉 +€87 esta semana
      </div>
    </div>
  </div>
</section>
