---
// Pricing.astro
const plans = [
  {
    id: 'digital',
    name: 'Gestión Digital',
    tag: 'Tu copiloto inteligente',
    price: '99',
    cta: 'Empezar ahora',
    href: '/empezar/',
    popular: false,
    features: [
      { icon: '✅', text: 'Optimización SEO: Tu anuncio en 1ª página de Airbnb/Booking' },
      { icon: '✅', text: 'Precios Dinámicos (IA): Actualización diaria para ganar un +20%' },
      { icon: '✅', text: 'Atención 24/7: Respondemos en minutos, día y noche' },
      { icon: '✅', text: 'Auto Check-in 24/7: Guías de acceso y códigos automáticos' },
      { icon: '✅', text: 'Registro de Viajeros (Policía) — España' },
      { icon: '✅', text: 'Filtrado Anti-Fiestas: Protegemos tu propiedad' },
      { icon: '✅', text: 'Sincronización Total: Adiós al overbooking entre plataformas' },
    ],
  },
  {
    id: '360',
    name: 'Gestión Operativa 360',
    tag: 'Plan más popular · Delegación total',
    price: '199',
    cta: 'Quiero delegar todo',
    href: '/empezar/',
    popular: true,
    features: [
      { icon: '🧹', text: 'Todo lo del Plan Digital incluido' },
      { icon: '🧹', text: 'Coordinación de Limpieza: Gestionamos tu equipo tras cada salida' },
      { icon: '🔧', text: 'Gestión de Mantenimiento: Resolvemos averías sin que te desplaces' },
      { icon: '🔐', text: 'Control de Accesos: Cerraduras inteligentes y cambio de códigos' },
      { icon: '📄', text: 'Gestión AirCover: Reclamamos daños y roturas por ti' },
      { icon: '👑', text: 'Soporte VIP: Línea directa de WhatsApp' },
      { icon: '📦', text: 'Control de Calidad: Revisión de inventario tras cada estancia' },
    ],
  },
];
---

<section id="precios" class="py-24 px-5">
  <div class="max-w-5xl mx-auto">

    <!-- Header -->
    <div class="text-center mb-14">
      <span class="inline-block text-xs text-brand-coral uppercase tracking-[0.2em] font-semibold mb-4">Precios</span>
      <h2 class="font-display font-bold text-4xl md:text-5xl text-white leading-tight">
        Planes simples. Sin comisiones.
      </h2>
      <p class="mt-4 text-brand-muted text-lg max-w-xl mx-auto">
        Tarifa fija por propiedad. <strong class="text-white">0% comisiones</strong>. 0% letra pequeña.
        Elige cuánto quieres delegar.
      </p>
    </div>

    <!-- Savings calculator callout -->
    <div class="mb-10 bg-brand-deep border border-brand-border rounded-2xl p-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm">
      <div class="flex items-center gap-3">
        <div class="text-3xl">📊</div>
        <div>
          <p class="text-white font-semibold">Ejemplo real: €3.000/mes de ingresos</p>
          <p class="text-brand-muted">Gestor tradicional 20%: pierdes <span class="text-red-400 font-semibold">€600/mes</span></p>
        </div>
      </div>
      <div class="text-right bg-emerald-500/10 border border-emerald-500/20 rounded-xl px-5 py-3">
        <p class="text-emerald-400 font-bold font-display text-xl">Ahorras €401/mes</p>
        <p class="text-brand-muted text-xs">= €4.812 al año con Hola Rentia</p>
      </div>
    </div>

    <!-- Plan cards -->
    <div class="grid md:grid-cols-2 gap-6">
      {plans.map(plan => (
        <article
          class:list={[
            'relative rounded-3xl border p-8 flex flex-col transition-all duration-300 hover:-translate-y-1',
            plan.popular
              ? 'bg-gradient-to-b from-brand-coral/10 to-brand-card border-brand-coral/50 shadow-[0_0_40px_rgba(255,84,54,0.15)]'
              : 'bg-brand-card border-brand-border',
          ]}
        >
          {plan.popular && (
            <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-brand-coral text-white text-xs font-bold px-4 py-1.5 rounded-full uppercase tracking-widest whitespace-nowrap">
              ⭐ Más popular
            </div>
          )}

          <div>
            <p class="text-xs text-brand-muted uppercase tracking-widest font-semibold mb-1">{plan.tag}</p>
            <h3 class="font-display font-bold text-2xl text-white mb-4">{plan.name}</h3>

            <div class="flex items-end gap-1 mb-1">
              <span class="font-display font-extrabold text-6xl text-white leading-none">€{plan.price}</span>
              <span class="text-brand-muted mb-2">/mes</span>
            </div>
            <p class="text-xs text-brand-muted mb-6">precio por propiedad · <span class="text-emerald-400 font-semibold">SIN PERMANENCIA</span></p>
          </div>

          <ul class="space-y-3 flex-1 mb-8">
            {plan.features.map(f => (
              <li class="flex items-start gap-3 text-sm text-brand-light/85">
                <span class="flex-shrink-0 mt-0.5">{f.icon}</span>
                <span>{f.text}</span>
              </li>
            ))}
          </ul>

          <a
            href={plan.href}
            class:list={[
              'block text-center font-bold py-4 rounded-2xl transition-all duration-300 hover:-translate-y-0.5',
              plan.popular
                ? 'bg-brand-coral hover:bg-orange-500 text-white hover:shadow-[0_0_25px_rgba(255,84,54,0.4)]'
                : 'bg-brand-border text-white hover:bg-brand-border/70',
            ]}
          >
            👉 {plan.cta}
          </a>

          <p class="text-center text-xs text-brand-muted mt-4">
            🔒 Prueba 30 días sin riesgo · Garantía de devolución
          </p>
        </article>
      ))}
    </div>

    <!-- Volume deal -->
    <div class="mt-8 text-center border border-dashed border-brand-border rounded-2xl py-6 px-4">
      <p class="text-white font-semibold">
        🏢 ¿Eres inversor con cartera inmobiliaria?
      </p>
      <p class="text-brand-muted text-sm mt-1 mb-4">
        Si tienes más de 3 propiedades, tenemos un plan especial para ti.
      </p>
      <a
        href="/empezar/"
        class="inline-flex items-center gap-2 text-brand-coral border border-brand-coral/40 hover:bg-brand-coral/10 font-semibold px-6 py-2.5 rounded-full text-sm transition-colors duration-200"
      >
        Consultar precio por volumen →
      </a>
    </div>
  </div>
</section>
