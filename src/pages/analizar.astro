---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Analizador de Propiedad IA | Calcula tu potencial en Airbnb | Hola Rentia"
  description="Descubre cuánto puedes ganar con tu propiedad en Airbnb. Análisis gratuito con IA en segundos: ingresos potenciales, precio por noche, temporada alta y más."
>

<style>
  :root {
    --red: #FF5436;
    --bg: #060d1a;
    --card: #0f1f35;
    --border: rgba(255,255,255,.08);
    --text: #e8edf8;
    --muted: #6b7a99;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: var(--bg); color: var(--text); font-family: 'Inter', system-ui, sans-serif; }

  .hero {
    text-align: center;
    padding: 80px 24px 48px;
    max-width: 700px;
    margin: 0 auto;
  }
  .badge {
    display: inline-block;
    background: rgba(255,84,54,.12);
    border: 1px solid rgba(255,84,54,.3);
    color: var(--red);
    font-size: .7rem;
    font-weight: 700;
    letter-spacing: .15em;
    text-transform: uppercase;
    padding: 5px 14px;
    border-radius: 50px;
    margin-bottom: 20px;
  }
  h1 {
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 800;
    line-height: 1.15;
    margin-bottom: 16px;
    color: #fff;
  }
  h1 em { color: var(--red); font-style: normal; }
  .sub { font-size: 1.05rem; color: var(--muted); line-height: 1.7; }

  /* Form card */
  .wrap { max-width: 860px; margin: 0 auto; padding: 0 24px 80px; }

  .form-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 24px;
    padding: 40px;
  }
  .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 28px; }
  @media(max-width:600px){ .form-grid { grid-template-columns: 1fr; } .form-card { padding: 24px; } }

  .fg { display: flex; flex-direction: column; gap: 8px; }
  label { font-size: .8rem; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: .08em; }
  input, select {
    background: rgba(255,255,255,.05);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 12px 16px;
    color: var(--text);
    font-size: .95rem;
    outline: none;
    transition: border-color .2s;
    width: 100%;
  }
  input:focus, select:focus { border-color: rgba(255,84,54,.5); }
  select option { background: #1e2a45; }

  .btn-analyze {
    width: 100%;
    background: var(--red);
    color: #fff;
    border: none;
    border-radius: 14px;
    padding: 16px;
    font-size: 1.05rem;
    font-weight: 700;
    cursor: pointer;
    transition: all .25s;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
  }
  .btn-analyze:hover { background: #e84528; box-shadow: 0 8px 30px rgba(255,84,54,.4); transform: translateY(-1px); }
  .btn-analyze:disabled { opacity: .6; cursor: not-allowed; transform: none; }

  /* Loading */
  #loading {
    display: none;
    text-align: center;
    padding: 60px 24px;
  }
  .spinner {
    width: 52px; height: 52px;
    border: 3px solid rgba(255,84,54,.2);
    border-top-color: var(--red);
    border-radius: 50%;
    animation: spin 1s linear infinite;
    margin: 0 auto 20px;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
  .loading-steps { list-style: none; display: flex; flex-direction: column; gap: 10px; max-width: 280px; margin: 20px auto 0; }
  .loading-steps li { font-size: .85rem; color: var(--muted); display: flex; align-items: center; gap: 10px; }
  .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--red); opacity: .3; animation: pulse 1.5s ease-in-out infinite; }
  .loading-steps li:nth-child(2) .dot { animation-delay: .3s; }
  .loading-steps li:nth-child(3) .dot { animation-delay: .6s; }
  @keyframes pulse { 0%,100%{opacity:.3;transform:scale(1)} 50%{opacity:1;transform:scale(1.4)} }

  /* Results */
  #results { display: none; }

  .result-header {
    background: linear-gradient(135deg, rgba(255,84,54,.15), rgba(255,84,54,.03));
    border: 1px solid rgba(255,84,54,.25);
    border-radius: 20px;
    padding: 32px;
    margin-bottom: 24px;
    text-align: center;
  }
  .result-header h2 { font-size: 1.4rem; color: #fff; margin-bottom: 8px; }
  .income-range {
    font-size: clamp(2.4rem, 6vw, 3.8rem);
    font-weight: 800;
    color: var(--red);
    line-height: 1;
    margin: 16px 0 8px;
  }
  .income-sub { color: var(--muted); font-size: .9rem; }

  .stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 24px; }
  @media(max-width:600px){ .stats-grid { grid-template-columns: 1fr 1fr; } }

  .stat-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 20px;
    text-align: center;
  }
  .stat-icon { font-size: 1.6rem; margin-bottom: 8px; }
  .stat-value { font-size: 1.5rem; font-weight: 800; color: #fff; margin-bottom: 4px; }
  .stat-label { font-size: .72rem; color: var(--muted); text-transform: uppercase; letter-spacing: .08em; }

  .section-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 24px;
    margin-bottom: 16px;
  }
  .section-title {
    font-size: .7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .12em;
    color: var(--muted);
    margin-bottom: 16px;
  }
  .mejora-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 12px 0;
    border-bottom: 1px solid var(--border);
    font-size: .9rem;
    color: #c8d4e8;
    line-height: 1.5;
  }
  .mejora-item:last-child { border-bottom: none; padding-bottom: 0; }
  .mejora-num {
    min-width: 26px;
    height: 26px;
    background: rgba(255,84,54,.15);
    border: 1px solid rgba(255,84,54,.3);
    color: var(--red);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: .75rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  .resumen-text { font-size: .95rem; color: #c8d4e8; line-height: 1.7; }

  .saving-box {
    background: rgba(34,197,94,.07);
    border: 1px solid rgba(34,197,94,.2);
    border-radius: 16px;
    padding: 24px;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 20px;
  }
  .saving-box .amount { font-size: 2.2rem; font-weight: 800; color: #22c55e; white-space: nowrap; }
  .saving-box p { font-size: .9rem; color: var(--muted); line-height: 1.6; }
  .saving-box strong { color: #e8edf8; }

  .cta-box {
    background: linear-gradient(135deg, rgba(255,84,54,.15), var(--card));
    border: 1px solid rgba(255,84,54,.3);
    border-radius: 20px;
    padding: 36px;
    text-align: center;
    margin-top: 8px;
  }
  .cta-box h3 { font-size: 1.4rem; color: #fff; margin-bottom: 10px; }
  .cta-box p { color: var(--muted); margin-bottom: 24px; font-size: .95rem; }
  .btn-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--red);
    color: #fff;
    font-weight: 700;
    font-size: 1rem;
    padding: 14px 32px;
    border-radius: 12px;
    text-decoration: none;
    transition: all .25s;
    border: none;
    cursor: pointer;
  }
  .btn-cta:hover { background: #e84528; box-shadow: 0 8px 30px rgba(255,84,54,.45); transform: translateY(-1px); }
  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: transparent;
    color: var(--muted);
    font-size: .9rem;
    padding: 12px 24px;
    border-radius: 12px;
    border: 1px solid var(--border);
    cursor: pointer;
    transition: all .2s;
    margin-top: 12px;
  }
  .btn-secondary:hover { color: var(--text); border-color: rgba(255,255,255,.2); }

  #error-msg {
    display: none;
    background: rgba(239,68,68,.08);
    border: 1px solid rgba(239,68,68,.25);
    border-radius: 10px;
    padding: 14px 18px;
    color: #fca5a5;
    font-size: .9rem;
    margin-top: 16px;
  }

  .tag-row { display: flex; gap: 8px; flex-wrap: wrap; }
  .tag {
    font-size: .75rem;
    background: rgba(255,255,255,.05);
    border: 1px solid var(--border);
    padding: 4px 12px;
    border-radius: 50px;
    color: var(--muted);
  }
  .tag.highlight { background: rgba(255,84,54,.1); border-color: rgba(255,84,54,.25); color: #ffb3a7; }
</style>

<!-- HERO -->
<section class="hero">
  <div class="badge">⚡ Análisis con IA · Gratuito · Instantáneo</div>
  <h1>Descubre cuánto puede<br>ganar tu propiedad en <em>Airbnb</em></h1>
  <p class="sub">Introduce los datos de tu piso y la IA analiza el mercado real de tu ciudad:<br>ingresos potenciales, precio óptimo por noche y qué mejorar.</p>
</section>

<div class="wrap">

  <!-- FORM -->
  <div class="form-card" id="form-section">
    <div class="form-grid">
      <div class="fg" style="grid-column: 1 / -1">
        <label>Ciudad de la propiedad *</label>
        <input type="text" id="ciudad" placeholder="Ej. Barcelona, Cancún, Medellín…" autocomplete="off" />
      </div>
      <div class="fg">
        <label>Tipo de propiedad</label>
        <select id="tipo">
          <option value="Apartamento">Apartamento</option>
          <option value="Casa">Casa / Chalet</option>
          <option value="Estudio">Estudio</option>
          <option value="Villa">Villa / Finca</option>
          <option value="Habitación privada">Habitación privada</option>
        </select>
      </div>
      <div class="fg">
        <label>Número de habitaciones</label>
        <select id="habitaciones">
          <option value="Estudio">Estudio (sin hab.)</option>
          <option value="1 habitación">1 habitación</option>
          <option value="2 habitaciones" selected>2 habitaciones</option>
          <option value="3 habitaciones">3 habitaciones</option>
          <option value="4 habitaciones">4 habitaciones</option>
          <option value="5 o más habitaciones">5 o más habitaciones</option>
        </select>
      </div>
      <div class="fg">
        <label>Estado actual</label>
        <select id="estado">
          <option value="No está en Airbnb aún">No está en Airbnb aún</option>
          <option value="Recién publicada en Airbnb">Recién publicada en Airbnb</option>
          <option value="Ya en Airbnb con reservas">Ya en Airbnb con reservas</option>
          <option value="Gestionada por otra empresa">Gestionada por otra empresa</option>
          <option value="Alquiler de larga duración actualmente">Alquiler de larga duración</option>
        </select>
      </div>
      <div class="fg">
        <label>Ingresos mensuales actuales (aprox.)</label>
        <select id="ingresos_actuales">
          <option value="Ninguno (no está en Airbnb)">Ninguno (no en Airbnb)</option>
          <option value="Menos de €500/mes">Menos de €500/mes</option>
          <option value="€500 – €1.000/mes">€500 – €1.000/mes</option>
          <option value="€1.000 – €2.000/mes">€1.000 – €2.000/mes</option>
          <option value="€2.000 – €3.500/mes">€2.000 – €3.500/mes</option>
          <option value="Más de €3.500/mes">Más de €3.500/mes</option>
        </select>
      </div>
    </div>

    <button class="btn-analyze" id="btn-analyze" onclick="runAnalysis()">
      <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
      </svg>
      Analizar mi propiedad con IA
    </button>
    <div id="error-msg"></div>
  </div>

  <!-- LOADING -->
  <div id="loading">
    <div class="spinner"></div>
    <p style="color:#e8edf8;font-weight:600;font-size:1.05rem;margin-bottom:8px">Analizando el mercado…</p>
    <p style="color:var(--muted);font-size:.85rem;margin-bottom:20px">La IA está procesando datos reales de Airbnb</p>
    <ul class="loading-steps">
      <li><span class="dot"></span>Consultando precios en tu ciudad</li>
      <li><span class="dot"></span>Calculando ocupación estimada</li>
      <li><span class="dot"></span>Generando recomendaciones personalizadas</li>
    </ul>
  </div>

  <!-- RESULTS -->
  <div id="results">
    <!-- Ingresos potenciales -->
    <div class="result-header">
      <h2>📊 Análisis de tu propiedad en <span id="res-ciudad"></span></h2>
      <p class="income-sub" style="margin-bottom:8px">Ingreso potencial mensual estimado</p>
      <div class="income-range" id="res-income">—</div>
      <p class="income-sub">con gestión optimizada en Airbnb</p>
    </div>

    <!-- Stats -->
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-icon">🌙</div>
        <div class="stat-value" id="res-precio">—</div>
        <div class="stat-label">Precio/noche recomendado</div>
      </div>
      <div class="stat-card">
        <div class="stat-icon">📅</div>
        <div class="stat-value" id="res-ocupacion">—</div>
        <div class="stat-label">Ocupación estimada</div>
      </div>
      <div class="stat-card">
        <div class="stat-icon">📈</div>
        <div class="stat-value" id="res-roi">—</div>
        <div class="stat-label">Mejora potencial</div>
      </div>
    </div>

    <!-- Ahorro vs gestor -->
    <div class="saving-box">
      <div class="amount" id="res-ahorro">—</div>
      <p><strong>de ahorro mensual</strong> vs un gestor tradicional que te cobra el 20%.<br>
      Con Hola Rentia pagas solo €199/mes y te quedas con el resto.</p>
    </div>

    <!-- Mejoras -->
    <div class="section-card">
      <div class="section-title">🔧 Top 3 mejoras para maximizar ingresos</div>
      <div id="res-mejoras"></div>
    </div>

    <!-- Mercado y temporada -->
    <div class="section-card">
      <div class="section-title">🌍 Mercado y temporada</div>
      <p class="resumen-text" id="res-competencia" style="margin-bottom:12px"></p>
      <div class="tag-row">
        <span class="tag">📆 Temporada alta:</span>
        <span class="tag highlight" id="res-temporada">—</span>
      </div>
    </div>

    <!-- Resumen IA -->
    <div class="section-card">
      <div class="section-title">🤖 Análisis de KATIA</div>
      <p class="resumen-text" id="res-resumen"></p>
    </div>

    <!-- CTA -->
    <div class="cta-box">
      <h3>🚀 ¿Listo para ganar este potencial?</h3>
      <p>Hola Rentia gestiona tu propiedad con IA desde €99/mes.<br>Sin comisiones. Sin permanencia. Resultados en 30 días.</p>
      <a href="/#formulario" class="btn-cta">Empezar ahora — Gratis →</a>
      <br>
      <button class="btn-secondary" onclick="resetAnalysis()">← Analizar otra propiedad</button>
    </div>
  </div>

</div>

<script>
async function runAnalysis() {
  const ciudad = document.getElementById('ciudad').value.trim();
  if (!ciudad) {
    showError('Por favor introduce la ciudad de tu propiedad.');
    return;
  }

  const btn = document.getElementById('btn-analyze');
  const errDiv = document.getElementById('error-msg');
  errDiv.style.display = 'none';
  btn.disabled = true;
  btn.innerHTML = '<div style="width:20px;height:20px;border:2px solid rgba(255,255,255,.3);border-top-color:#fff;border-radius:50%;animation:spin 1s linear infinite"></div> Analizando…';

  document.getElementById('form-section').style.display = 'none';
  document.getElementById('loading').style.display = 'block';

  try {
    const res = await fetch('/api/analyze', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        ciudad,
        tipo: document.getElementById('tipo').value,
        habitaciones: document.getElementById('habitaciones').value,
        estado: document.getElementById('estado').value,
        ingresos_actuales: document.getElementById('ingresos_actuales').value,
      }),
    });

    const data = await res.json();
    document.getElementById('loading').style.display = 'none';

    if (data.error) {
      document.getElementById('form-section').style.display = 'block';
      showError('Error: ' + data.error);
      btn.disabled = false;
      btn.innerHTML = '⚡ Analizar mi propiedad con IA';
      return;
    }

    renderResults(ciudad, data.analysis);

  } catch (err) {
    document.getElementById('loading').style.display = 'none';
    document.getElementById('form-section').style.display = 'block';
    showError('Error de conexión. Inténtalo de nuevo.');
    btn.disabled = false;
    btn.innerHTML = '⚡ Analizar mi propiedad con IA';
  }
}

function renderResults(ciudad, a) {
  document.getElementById('res-ciudad').textContent = ciudad;
  document.getElementById('res-income').textContent = `€${Number(a.ingreso_potencial_min).toLocaleString('es')} – €${Number(a.ingreso_potencial_max).toLocaleString('es')}`;
  document.getElementById('res-precio').textContent = `€${Number(a.precio_noche_recomendado).toLocaleString('es')}`;
  document.getElementById('res-ocupacion').textContent = `${a.ocupacion_estimada}%`;
  document.getElementById('res-roi').textContent = `+${a.roi_anual}%`;
  document.getElementById('res-ahorro').textContent = `€${Number(a.ahorro_vs_gestor).toLocaleString('es')}/mes`;
  document.getElementById('res-competencia').textContent = a.competencia || '';
  document.getElementById('res-temporada').textContent = a.temporada_alta || '—';
  document.getElementById('res-resumen').textContent = a.resumen || '';

  const mejorasEl = document.getElementById('res-mejoras');
  mejorasEl.innerHTML = '';
  (a.top3_mejoras || []).forEach((m, i) => {
    const div = document.createElement('div');
    div.className = 'mejora-item';
    div.innerHTML = `<span class="mejora-num">${i + 1}</span><span>${m}</span>`;
    mejorasEl.appendChild(div);
  });

  document.getElementById('results').style.display = 'block';
}

function showError(msg) {
  const el = document.getElementById('error-msg');
  el.textContent = msg;
  el.style.display = 'block';
}

function resetAnalysis() {
  document.getElementById('results').style.display = 'none';
  document.getElementById('form-section').style.display = 'block';
  const btn = document.getElementById('btn-analyze');
  btn.disabled = false;
  btn.innerHTML = `<svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg> Analizar mi propiedad con IA`;
}
</script>

</Layout>
