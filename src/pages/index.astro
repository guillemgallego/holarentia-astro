<script>
(function(){
'use strict';

/* ── Navbar scroll ── */
const nav=document.getElementById('nav');
let ticking=false;
window.addEventListener('scroll',()=>{
  if(!ticking){requestAnimationFrame(()=>{nav.classList.toggle('scrolled',window.scrollY>50);ticking=false});ticking=true}
},{passive:true});

/* ── Mobile nav ── */
const mNav=document.getElementById('mob-nav');
const mBtn=document.getElementById('mob-btn');
const mX=document.getElementById('mob-close');
function closeMob(){mNav.classList.remove('open');mNav.setAttribute('aria-hidden','true');if(mBtn)mBtn.setAttribute('aria-expanded','false')}
if(mBtn)mBtn.addEventListener('click',()=>{mNav.classList.add('open');mNav.setAttribute('aria-hidden','false');mBtn.setAttribute('aria-expanded','true')});
if(mX)mX.addEventListener('click',closeMob);
mNav.querySelectorAll('a').forEach(a=>a.addEventListener('click',closeMob));

/* ── Scroll reveal ── */
const io=new IntersectionObserver(entries=>{
  entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('visible');io.unobserve(e.target)}});
},{threshold:.1,rootMargin:'0px 0px -44px 0px'});
document.querySelectorAll('.reveal').forEach(el=>io.observe(el));

/* ── FAQ accordion ── */
document.querySelectorAll('.fi-q').forEach(btn=>{
  btn.addEventListener('click',()=>{
    const item=btn.parentElement;
    const ans=item.querySelector('.fi-a');
    const open=item.classList.contains('open');
    document.querySelectorAll('.fi-item').forEach(fi=>{
      fi.classList.remove('open');
      fi.querySelector('.fi-a').style.maxHeight='0';
      fi.querySelector('.fi-q').setAttribute('aria-expanded','false');
    });
    if(!open){item.classList.add('open');ans.style.maxHeight=ans.scrollHeight+'px';btn.setAttribute('aria-expanded','true')}
  });
});

/* ── Stars fill ── */
const sp='<path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>';
document.querySelectorAll('.stars svg').forEach(s=>s.innerHTML=sp);

/* ── Calculadora ── */
const rng=document.getElementById('income-range');
const disp=document.getElementById('income-display');
const tradLoss=document.getElementById('trad-loss');
const rentiaCost=document.getElementById('rentia-cost');
const totalSaving=document.getElementById('total-saving');
const yearlySaving=document.getElementById('yearly-saving');
function fmt(n){return'€'+n.toLocaleString('es-ES')}
function updateCalc(){
  const income=parseInt(rng.value);
  const min=parseInt(rng.min);const max=parseInt(rng.max);
  rng.style.setProperty('--val',((income-min)/(max-min)*100).toFixed(2)+'%');
  disp.textContent=fmt(income);
  const loss=Math.round(income*.20);
  const plan=income>=3000?199:99;
  const saving=loss-plan;
  tradLoss.textContent=fmt(loss)+'/mes';
  rentiaCost.textContent=fmt(plan)+'/mes';
  totalSaving.textContent=fmt(saving)+'/mes';
  yearlySaving.textContent=fmt(saving*12);
}
if(rng){rng.addEventListener('input',updateCalc);updateCalc()}

/* ── Lead form ── */
const form=document.getElementById('lead-form');
const formSuccess=document.getElementById('form-success');
const formSubmit=document.getElementById('form-submit');
if(form){
  form.addEventListener('submit',async e=>{
    e.preventDefault();
    formSubmit.textContent='Enviando…';formSubmit.disabled=true;
    try{
      const res=await fetch(form.action,{method:'POST',body:new FormData(form),headers:{Accept:'application/json'}});
      if(res.ok){form.style.display='none';formSuccess.style.display='block'}
      else{formSubmit.textContent='Error, inténtalo de nuevo';formSubmit.disabled=false}
    }catch{formSubmit.textContent='Error de conexión';formSubmit.disabled=false}
  });
}

})();
</script>
</body>
</html>
