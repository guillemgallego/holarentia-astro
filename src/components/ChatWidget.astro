---
---
<div id="chat-widget" class="chat-widget-container">
  
  <button id="chat-toggle" class="chat-toggle-btn" aria-label="Abrir chat">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path id="chat-icon-path" stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
    </svg>
  </button>

  <div id="chat-window" class="chat-window hidden">
    <div class="chat-header">
      <div class="header-info">
        <div class="avatar-icon">
          <svg style="color:white;width:20px;height:20px" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
             <path d="M12 8V4H8"></path><rect width="16" height="12" x="4" y="8" rx="2"></rect><path d="M2 14h2"></path><path d="M20 14h2"></path><path d="M15 13v2"></path><path d="M9 13v2"></path>
          </svg>
        </div>
        <div class="header-text">
          <h3>Asistente IA</h3>
          <p class="status"><span class="pulse-dot"></span>En línea</p>
        </div>
      </div>
      <button id="chat-close" class="close-btn" aria-label="Cerrar chat">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <div id="chat-messages" class="chat-messages">
      <div class="message-row">
        <div class="message bot">
          ¡Hola! Soy la IA de Hola Rentia 👋<br><br>¿Tienes dudas sobre cómo gestionamos tu alojamiento sin comisiones?
        </div>
      </div>
    </div>

    <div class="chat-footer">
      <form id="chat-form">
        <input type="text" id="chat-input" placeholder="Pregúntame algo..." autocomplete="off">
        <button type="submit" id="chat-submit" aria-label="Enviar">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </button>
      </form>
    </div>
  </div>
</div>

<style>
  .chat-widget-container {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 9999;
    font-family: var(--font-b, system-ui, sans-serif);
  }
  .chat-toggle-btn {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: var(--g-ai, var(--red));
    color: white;
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--sh-red, 0 8px 28px rgba(255,59,48,0.28));
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .chat-toggle-btn:hover {
    transform: scale(1.05);
    background: var(--g-ai-h, var(--red-d));
  }
  .chat-window {
    position: absolute;
    bottom: 80px;
    right: 0;
    width: clamp(300px, calc(100vw - 48px), 380px);
    height: 500px;
    max-height: 70vh;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--r-xl, 24px);
    box-shadow: var(--sh-lg);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transform-origin: bottom right;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  .chat-window.hidden {
    display: none;
    opacity: 0;
    transform: translateY(20px) scale(0.95);
  }
  .chat-window.show {
    display: flex;
    opacity: 1;
    transform: translateY(0) scale(1);
  }
  .chat-header {
    background: var(--text);
    padding: 16px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: white;
  }
  .header-info { display: flex; align-items: center; gap: 12px; }
  .avatar-icon {
    width: 36px; height: 36px; border-radius: 50%;
    background: rgba(255,255,255,0.1);
    display: flex; align-items: center; justify-content: center;
  }
  .header-text h3 { margin: 0; font-size: 1rem; font-family: var(--font-d); }
  .status { margin: 0; font-size: 0.8rem; color: #cbd5e1; display: flex; align-items: center; gap: 6px; }
  .pulse-dot { width: 6px; height: 6px; background: #22c55e; border-radius: 50%; opacity: 0.8; }
  .close-btn { background: none; border: none; color: white; opacity: 0.7; padding: 4px; border-radius: 4px; }
  .close-btn:hover { opacity: 1; background: rgba(255,255,255,0.1); }
  .chat-messages {
    flex: 1; padding: 16px; overflow-y: auto; display: flex; flex-direction: column; gap: 12px; background: var(--bg2);
  }
  .message-row { display: flex; }
  .message-row.user { justify-content: flex-end; }
  .message {
    max-width: 85%; padding: 12px 16px; border-radius: var(--r-lg, 16px);
    font-size: 0.95rem; line-height: 1.5;
  }
  .message.bot { background: white; border: 1px solid var(--border); border-top-left-radius: 4px; color: var(--text2); }
  .message.user { background: var(--red); color: white; border-top-right-radius: 4px; }
  .chat-footer { padding: 12px; background: white; border-top: 1px solid var(--border); }
  #chat-form { display: flex; gap: 8px; position: relative; }
  #chat-input {
    flex: 1; padding: 12px 16px; padding-right: 48px; border: 1px solid var(--border);
    border-radius: 50px; outline: none; font-family: inherit; font-size: 0.95rem;
    transition: border-color 0.2s;
  }
  #chat-input:focus { border-color: var(--orange); }
  #chat-submit {
    position: absolute; right: 4px; top: 4px; bottom: 4px; width: 38px;
    background: var(--g-ai, var(--red)); color: white; border: none; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
  }
  #chat-submit:disabled { opacity: 0.5; }
</style>

<script>
  let isChatOpen = false;
  let chatHistory = [];
  const chatWindow = document.getElementById('chat-window');
  const toggleBtn = document.getElementById('chat-toggle');
  const closeBtn = document.getElementById('chat-close');
  const chatIconPath = document.getElementById('chat-icon-path');
  const chatMessages = document.getElementById('chat-messages');
  const chatForm = document.getElementById('chat-form');
  const chatInput = document.getElementById('chat-input') as HTMLInputElement;
  const chatSubmit = document.getElementById('chat-submit') as HTMLButtonElement;

  const ICON_CHAT = "M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z";
  const ICON_CLOSE = "M6 18L18 6M6 6l12 12";

  function toggle() {
    isChatOpen = !isChatOpen;
    if (isChatOpen) {
      chatWindow.classList.remove('hidden');
      requestAnimationFrame(() => chatWindow.classList.add('show'));
      chatIconPath.setAttribute('d', ICON_CLOSE);
      setTimeout(() => chatInput.focus(), 300);
    } else {
      chatWindow.classList.remove('show');
      setTimeout(() => chatWindow.classList.add('hidden'), 300);
      chatIconPath.setAttribute('d', ICON_CHAT);
    }
  }

  toggleBtn.addEventListener('click', toggle);
  closeBtn.addEventListener('click', toggle);

  function appendMsg(text, isUser) {
    const row = document.createElement('div');
    row.className = `message-row ${isUser ? 'user' : ''}`;
    row.innerHTML = `<div class="message ${isUser ? 'user' : 'bot'}">${text.replace(/\n/g, '<br>')}</div>`;
    chatMessages.appendChild(row);
    chatMessages.scrollTo({ top: chatMessages.scrollHeight, behavior: 'smooth' });
  }

  function appendLoading() {
    const row = document.createElement('div');
    row.id = 'chat-loading';
    row.className = 'message-row';
    row.innerHTML = `<div class="message bot"><span style="opacity:0.5">Escribiendo...</span></div>`;
    chatMessages.appendChild(row);
    chatMessages.scrollTo({ top: chatMessages.scrollHeight, behavior: 'smooth' });
  }
  function removeLoading() {
    const loading = document.getElementById('chat-loading');
    if (loading) loading.remove();
  }

  chatForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const msg = chatInput.value.trim();
    if (!msg) return;

    chatInput.value = '';
    appendMsg(msg, true);
    appendLoading();
    chatInput.disabled = true;
    chatSubmit.disabled = true;

    try {
      const res = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: msg, history: chatHistory })
      });
      const data = await res.json();
      removeLoading();
      
      if (!res.ok) throw new Error(data.error);
      
      appendMsg(data.response, false);
      chatHistory.push({ role: 'user', parts: [{ text: msg }] });
      chatHistory.push({ role: 'model', parts: [{ text: data.response }] });
    } catch (err) {
      removeLoading();
      appendMsg("❌ Hubo un error de conexión con la IA.", false);
    } finally {
      chatInput.disabled = false;
      chatSubmit.disabled = false;
      chatInput.focus();
    }
  });
</script>
