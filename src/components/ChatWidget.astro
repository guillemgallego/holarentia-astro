---
---
<div id="chat-widget" style="position:fixed;bottom:92px;left:24px;z-index:9999;">

  <!-- Botón Flotante -->
  <button id="chat-toggle" aria-label="Abrir chat" style="width:56px;height:56px;border-radius:50%;background:#FF5436;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;box-shadow:0 8px 30px rgba(0,0,0,0.2);">
    <svg id="chat-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="2">
      <path id="chat-icon-path" stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
    </svg>
  </button>

  <!-- Ventana de Chat -->
  <div id="chat-window" style="display:none;position:absolute;bottom:68px;left:0;width:340px;max-width:calc(100vw - 48px);height:500px;max-height:75vh;flex-direction:column;background:#06091A;border:1px solid #1E2A45;border-radius:16px;box-shadow:0 20px 60px rgba(0,0,0,0.4);overflow:hidden;z-index:9999;">

    <!-- Cabecera -->
    <div style="background:#0D1226;padding:16px;border-bottom:1px solid #1E2A45;display:flex;justify-content:space-between;align-items:center;flex-shrink:0;">
      <div style="display:flex;align-items:center;gap:12px;">
        <div style="width:36px;height:36px;border-radius:50%;background:rgba(255,84,54,0.2);border:1px solid rgba(255,84,54,0.3);display:flex;align-items:center;justify-content:center;">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="#FF5436" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 8V4H8"></path>
            <rect width="16" height="12" x="4" y="8" rx="2"></rect>
            <path d="M2 14h2"></path><path d="M20 14h2"></path>
            <path d="M15 13v2"></path><path d="M9 13v2"></path>
          </svg>
        </div>
        <div>
          <div style="color:#E8EDF8;font-weight:600;font-size:14px;">KATIA</div>
          <div style="color:#6B7A99;font-size:12px;display:flex;align-items:center;gap:6px;">
            <span style="width:6px;height:6px;border-radius:50%;background:#22c55e;display:inline-block;"></span>
            En línea
          </div>
        </div>
      </div>
      <button id="chat-close" aria-label="Cerrar" style="background:none;border:none;cursor:pointer;color:#6B7A99;padding:4px;border-radius:6px;">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Mensajes -->
    <div id="chat-messages" style="flex:1;padding:16px;overflow-y:auto;display:flex;flex-direction:column;gap:12px;">
      <div style="display:flex;justify-content:flex-start;">
        <div style="background:#111827;border:1px solid #1E2A45;color:#E8EDF8;font-size:13px;padding:12px 16px;border-radius:16px 16px 16px 4px;max-width:85%;line-height:1.5;">
          ¡Hola! Soy KATIA, la asistente IA de Hola Rentia 👋<br><br>¿Tienes dudas sobre cómo gestionamos tu alojamiento turístico sin comisiones?
        </div>
      </div>
    </div>

    <!-- Input -->
    <div style="padding:12px;background:#0D1226;border-top:1px solid #1E2A45;flex-shrink:0;">
      <form id="chat-form" style="display:flex;align-items:center;gap:8px;position:relative;">
        <input
          type="text"
          id="chat-input"
          placeholder="Escribe tu mensaje..."
          autocomplete="off"
          style="flex:1;background:#111827;border:1px solid #1E2A45;color:#E8EDF8;font-size:13px;border-radius:999px;padding:10px 48px 10px 16px;outline:none;width:100%;"
        >
        <button type="submit" id="chat-submit" style="position:absolute;right:6px;width:32px;height:32px;border-radius:50%;background:#FF5436;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </button>
      </form>
    </div>
  </div>
</div>

<script>
  const toggleBtn    = document.getElementById('chat-toggle');
  const closeBtn     = document.getElementById('chat-close');
  const chatWindow   = document.getElementById('chat-window');
  const chatIconPath = document.getElementById('chat-icon-path');
  const chatForm     = document.getElementById('chat-form');
  const chatInput    = document.getElementById('chat-input');
  const chatMessages = document.getElementById('chat-messages');
  const submitBtn    = document.getElementById('chat-submit');

  let isOpen = false;
  let chatHistory = [];

  const ICON_OPEN  = "M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z";
  const ICON_CLOSE = "M6 18L18 6M6 6l12 12";

  function toggleChat() {
    isOpen = !isOpen;
    chatWindow.style.display = isOpen ? 'flex' : 'none';
    chatWindow.style.flexDirection = 'column';
    chatIconPath.setAttribute('d', isOpen ? ICON_CLOSE : ICON_OPEN);
    if (isOpen) setTimeout(() => chatInput.focus(), 100);
  }

  toggleBtn.addEventListener('click', toggleChat);
  closeBtn.addEventListener('click', toggleChat);

  function addMessage(text, isUser) {
    const wrap = document.createElement('div');
    wrap.style.cssText = `display:flex;justify-content:${isUser ? 'flex-end' : 'flex-start'};`;
    const bubble = document.createElement('div');
    bubble.style.cssText = isUser
      ? 'background:#FF5436;color:#fff;font-size:13px;padding:10px 14px;border-radius:16px 16px 4px 16px;max-width:85%;line-height:1.5;'
      : 'background:#111827;border:1px solid #1E2A45;color:#E8EDF8;font-size:13px;padding:10px 14px;border-radius:16px 16px 16px 4px;max-width:85%;line-height:1.5;';
    bubble.innerHTML = text.replace(/\n/g, '<br>');
    wrap.appendChild(bubble);
    chatMessages.appendChild(wrap);
    chatMessages.scrollTop = chatMessages.scrollHeight;
  }

  function addLoading() {
    const wrap = document.createElement('div');
    wrap.id = 'chat-loading';
    wrap.style.cssText = 'display:flex;justify-content:flex-start;';
    wrap.innerHTML = `<div style="background:#111827;border:1px solid #1E2A45;padding:12px 16px;border-radius:16px 16px 16px 4px;">
      <div style="display:flex;gap:5px;align-items:center;">
        <span style="width:7px;height:7px;background:#6B7A99;border-radius:50%;animation:bounce 1s infinite 0ms;display:inline-block;"></span>
        <span style="width:7px;height:7px;background:#6B7A99;border-radius:50%;animation:bounce 1s infinite 150ms;display:inline-block;"></span>
        <span style="width:7px;height:7px;background:#6B7A99;border-radius:50%;animation:bounce 1s infinite 300ms;display:inline-block;"></span>
      </div>
    </div>`;
    chatMessages.appendChild(wrap);
    chatMessages.scrollTop = chatMessages.scrollHeight;
  }

  chatForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const message = chatInput.value.trim();
    if (!message) return;

    chatInput.value = '';
    addMessage(message, true);
    addLoading();
    submitBtn.disabled = true;
    chatInput.disabled = true;

    try {
      const res = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message, history: chatHistory })
      });

      const data = await res.json();
      document.getElementById('chat-loading')?.remove();

      if (!res.ok || data.error) throw new Error(data.error || `Error ${res.status}`);

      addMessage(data.response, false);
      chatHistory.push({ role: 'user', content: message });
      chatHistory.push({ role: 'assistant', content: data.response });

    } catch (err) {
      document.getElementById('chat-loading')?.remove();
      addMessage('Error: ' + err.message, false);
    } finally {
      submitBtn.disabled = false;
      chatInput.disabled = false;
      chatInput.focus();
    }
  });
</script>

<style>
  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-5px); }
  }
</style>
