---
// Comparison.astro
const rows = [
  { feature: 'Modelo de cobro',     us: 'Tarifa plana fija',          them: '20–30% de comisión' },
  { feature: 'Tecnología',          us: 'IA + Equipo Humano',         them: 'Procesos manuales' },
  { feature: 'Velocidad de respuesta', us: 'Minutos (24/7)',          them: 'Horario de oficina' },
  { feature: 'Transparencia',       us: 'Ingresos 100% a tu cuenta',  them: 'Costes ocultos en reparaciones' },
  { feature: 'Permanencia',         us: 'Sin permanencia',            them: 'Contratos largos' },
];
---

<section class="py-20 px-5 bg-brand-deep/40">
  <div class="max-w-4xl mx-auto">

    <div class="text-center mb-12">
      <span class="inline-block text-xs text-brand-coral uppercase tracking-[0.2em] font-semibold mb-4">Comparativa</span>
      <h2 class="font-display font-bold text-3xl md:text-4xl text-white">
        Nosotros vs los gestores tradicionales
      </h2>
    </div>

    <div class="rounded-3xl overflow-hidden border border-brand-border">
      <!-- Table head -->
      <div class="grid grid-cols-3 bg-brand-card">
        <div class="p-5 text-xs uppercase tracking-widest text-brand-muted font-semibold">Característica</div>
        <div class="p-5 text-center border-l border-brand-border">
          <span class="inline-block bg-brand-coral text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide">Hola Rentia</span>
        </div>
        <div class="p-5 text-center border-l border-brand-border text-sm text-brand-muted font-semibold">Otros gestores</div>
      </div>

      <!-- Rows -->
      {rows.map((row, i) => (
        <div class:list={['grid grid-cols-3 border-t border-brand-border', i % 2 === 0 ? 'bg-brand-deep/30' : '']}>
          <div class="p-5 text-sm text-brand-light/80 font-medium flex items-center">{row.feature}</div>
          <div class="p-5 border-l border-brand-border text-center">
            <span class="inline-flex items-center gap-1.5 text-emerald-400 text-sm font-semibold">
              <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              {row.us}
            </span>
          </div>
          <div class="p-5 border-l border-brand-border text-center">
            <span class="inline-flex items-center gap-1.5 text-red-400 text-sm">
              <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/>
              </svg>
              {row.them}
            </span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
