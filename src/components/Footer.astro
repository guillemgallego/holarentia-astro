---
// src/components/Footer.astro — Hola Rentia · Mega Footer SEO
---
<footer role="contentinfo" aria-label="Pie de página">
  <div class="f-wrap">

    <!-- ══ TOP BAND ══ -->
    <div class="f-top">
      <div class="fb">
        <a href="/" aria-label="Hola Rentia – Software de gestión de alquiler vacacional">
          <img
            src="/images/hola-rentia-logo-gestion-airbnb-ia.webp"
            alt="Hola Rentia – Software Alquiler Vacacional con IA"
            class="f-logo"
            width="260" height="68"
            loading="lazy" decoding="async"
          />
        </a>
        <p class="f-tagline">Software de alquiler vacacional con IA.<br>0% comisiones · Pagos directos · IA + equipo humano.</p>
        <div class="fchips">
          <span class="fchip">✔ 0% comisiones</span>
          <span class="fchip">✔ Sin permanencia</span>
          <span class="fchip">✔ Garantía 30 días</span>
          <span class="fchip">⭐ 4.9/5 en reseñas</span>
        </div>
        <div class="f-socials">
          <a href="https://wa.me/34642017089" target="_blank" rel="noopener noreferrer" class="f-social" aria-label="WhatsApp Hola Rentia">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" fill="currentColor"/></svg>
          </a>
          <a href="mailto:hola@holarentia.com" class="f-social" aria-label="Email Hola Rentia">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          </a>
        </div>
      </div>

      <!-- Nav: Producto -->
      <div class="f-col">
        <p class="fh">Producto</p>
        <ul class="f-links">
          <li><a href="/#funciona">Cómo funciona</a></li>
          <li><a href="/#channel-manager">Channel Manager</a></li>
          <li><a href="/#automatizacion">Automatización IA</a></li>
          <li><a href="/#precios">Planes y precios</a></li>
          <li><a href="/#testimonios">Clientes y reseñas</a></li>
          <li><a href="/#formulario">Análisis gratuito</a></li>
        </ul>
      </div>

      <!-- Nav: Recursos Legales -->
      <div class="f-col">
        <p class="fh">Recursos Legales</p>
        <ul class="f-links">
          <li><a href="/es/recursos-legales">Centro de Recursos</a></li>
          <li><a href="/es/recursos-legales/espana">⚖ Guía Legal España</a></li>
          <li><a href="/es/recursos-legales/mexico">⚖ Guía Legal México</a></li>
          <li><a href="/es/recursos-legales/colombia">⚖ Guía Legal Colombia</a></li>
          <li><a href="/es/recursos-legales/argentina">⚖ Guía Legal Argentina</a></li>
          <li><a href="/es/recursos-legales/chile">⚖ Guía Legal Chile</a></li>
        </ul>
      </div>

      <!-- Nav: Por País -->
      <div class="f-col">
        <p class="fh">Por país</p>
        <ul class="f-links">
          <li><a href="/es/espana">🇪🇸 España</a></li>
          <li><a href="/es/mexico">🇲🇽 México</a></li>
          <li><a href="/colombia/">🇨🇴 Colombia</a></li>
          <li><a href="/es/argentina">🇦🇷 Argentina</a></li>
          <li><a href="/es/chile">🇨🇱 Chile</a></li>
          <li><a href="/es/peru">🇵🇪 Perú</a></li>
        </ul>
      </div>

      <!-- Nav: Ciudades + Contacto -->
      <div class="f-col">
        <p class="fh">Ciudades destacadas</p>
        <ul class="f-links">
          <li><a href="/colombia/medellin/">Medellín</a></li>
          <li><a href="/es/espana">Barcelona · Madrid</a></li>
          <li><a href="/es/mexico">Cancún · Los Cabos</a></li>
          <li><a href="/es/argentina">Buenos Aires · Bariloche</a></li>
          <li><a href="/es/chile">Santiago · Atacama</a></li>
          <li><a href="/es/republica-dominicana">Punta Cana · Samaná</a></li>
          <li><a href="/es/costa-rica">Guanacaste · Manuel Antonio</a></li>
          <li><a href="/es/uruguay">Punta del Este</a></li>
        </ul>
        <p class="fh" style="margin-top:24px">Contacto</p>
        <div class="clinks">
          <a href="mailto:hola@holarentia.com" class="clink">
            <span class="cico" aria-hidden="true">📧</span>
            hola@holarentia.com
          </a>
          <a href="https://wa.me/34642017089" target="_blank" rel="noopener noreferrer" class="clink">
            <span class="cico" aria-hidden="true">💬</span>
            WhatsApp · &lt;2h respuesta
          </a>
        </div>
        <a href="/#formulario" class="btn-fire-sm">🔍 Análisis gratuito</a>
      </div>
    </div>

    <!-- ══ PAGOS SEGUROS ══ -->
    <div class="pay-strip">
      <span class="pay-label">🛡️ Procesamiento seguro de pagos</span>
      <div class="pay-logos">
        <!-- Stripe -->
        <div class="pay-badge" title="Stripe">
          <svg viewBox="0 0 60 25" style="height:20px;width:auto" aria-label="Stripe">
            <path d="M28.3 9.3c0-.9.7-1.2 1.9-1.2 1.7 0 3.8.5 5.5 1.4V5.1c-1.8-.7-3.7-1-5.5-1C26.4 4.1 24 6 24 9.5c0 5.4 7.4 4.5 7.4 6.9 0 1-.9 1.4-2.2 1.4-1.9 0-4.3-.8-6.2-1.9v4.5c2.1.9 4.2 1.3 6.2 1.3 4.7 0 7.9-2.3 7.9-5.9-.1-5.8-7.8-4.8-7.8-6.5z" fill="#635BFF"/>
            <path d="M8 4.4L3.8 5.3l-.1 12.8c0 2.4 1.8 4.1 4.2 4.1 1.3 0 2.3-.2 2.8-.5v-3.6c-.5.2-3 .9-3-1.4V9h3V5.2H7.7L8 4.4z" fill="#635BFF"/>
            <path d="M14.8 6.7L14.5 5H10.8v16.9h4.4v-11c1-1.3 2.8-1.1 3.3-.9V5.1c-.6-.2-2.6-.6-3.7 1.6z" fill="#635BFF"/>
            <path d="M22.2 5H17.8v16.9h4.4V5z" fill="#635BFF"/>
            <path d="M47.2 5h-4.4l-.1 1.4C41.7 5.4 40.3 4.7 38.6 4.7c-4.1 0-7.5 3.3-7.5 8.8S34.5 22 38.6 22c1.7 0 3.1-.7 4.1-1.7l.1 1.4h4.4V5zm-7.5 12.9c-2.4 0-3.9-1.7-3.9-4.4s1.5-4.4 3.9-4.4c2.4 0 3.9 1.7 3.9 4.4s-1.5 4.4-3.9 4.4z" fill="#635BFF"/>
            <path d="M56.3 13.5l5.1-8.5h-5l-2.8 5-2.8-5H45.7l5.1 8.4-5.4 8.5h5l3-5.1 3 5.1h5.2l-5.3-8.4z" fill="#635BFF"/>
          </svg>
        </div>
        <!-- Visa -->
        <div class="pay-badge" title="Visa">
          <svg viewBox="0 0 60 20" style="height:16px;width:auto" aria-label="Visa">
            <path d="M24.7 1.3l-3.4 17.4h-4.1l3.4-17.4h4.1zM43.3 12.1l2.1-5.8.5 5.8h-2.6zm4.6 6.6H52L48.4 1.3h-3.8c-.9 0-1.6.5-1.9 1.3L36.6 18.7h4.4l.9-2.4h5.4l.6 2.4zm-10.8-5.7c0-4.4-6.1-4.7-6.1-6.6 0-.6.6-1.2 1.9-1.4.6-.1 2.4-.1 4.3.8l.8-3.5C36.8 1.8 35.4 1.3 33.7 1.3c-4.1 0-7 2.2-7 5.4 0 2.3 2.1 3.6 3.7 4.4 1.6.8 2.2 1.3 2.2 2 0 1.1-1.3 1.6-2.5 1.6-2.1 0-3.4-.6-4.3-1l-.8 3.6c1 .5 2.8.9 4.7.9 4.4 0 7.3-2.2 7.3-5.8zM16.8 1.3L9.9 18.7H5.3L1.9 4.7C1.7 3.8 1.4 3.5.7 3.1 0 2.7-.8 2.4-1.7 2.3l.1-.9h7.3c.9 0 1.7.6 1.9 1.7l1.8 9.4L13.8 1.3h4z" fill="#1A1F71"/>
          </svg>
        </div>
        <!-- Mastercard -->
        <div class="pay-badge" title="Mastercard">
          <svg viewBox="0 0 40 25" style="height:22px;width:auto" aria-label="Mastercard">
            <circle cx="12" cy="12.5" r="10" fill="#EB001B"/>
            <circle cx="28" cy="12.5" r="10" fill="#F79E1B"/>
            <path d="M14.5 4.5 C 18 6.5, 20 10.5, 20 12.5 S 18 18.5, 14.5 20.5 C 19.5 18.5, 21.5 14.5, 21.5 12.5 S 19.5 6.5, 14.5 4.5" fill="#FF5F00"/>
          </svg>
        </div>
        <!-- Apple Pay -->
        <div class="pay-badge" title="Apple Pay">
          <svg viewBox="0 0 40 16" style="height:18px;width:auto" aria-label="Apple Pay">
            <path d="M6.8 1.2c-.4.5-1 .9-1.6.8-.1-.6.2-1.2.5-1.6.4-.5 1-.8 1.6-.8.1.6-.2 1.2-.5 1.6zm.5.8c-.9-.1-1.7.5-2.1.5-.4 0-1.1-.5-1.8-.5C2.4 2 1.4 2.7 1 3.8c-.9 2.5.6 6.2 1.5 8.2.5.9 1.1 1.9 1.9 1.9.7 0 1-.5 1.9-.5s1.2.5 1.9.5c.8 0 1.4-1 1.9-1.9.6-.8.8-1.5.8-1.6-.1 0-1.5-.6-1.5-2.2 0-1.4 1.1-2 1.2-2.1-.7-1-1.7-1-2-1z" fill="#000"/>
            <text x="14" y="13" font-family="Arial, sans-serif" font-weight="bold" font-size="12" fill="#000">Pay</text>
          </svg>
        </div>
        <!-- Google Pay -->
        <div class="pay-badge" title="Google Pay">
          <svg viewBox="0 0 50 20" style="height:18px;width:auto" aria-label="Google Pay">
             <path d="M7.5 8.2v2.5h3.4c-.1 1.3-.9 2.2-2.4 2.2-1.7 0-3.1-1.4-3.1-3.2s1.4-3.2 3.1-3.2c.8 0 1.5.3 2.1.8l1.8-1.8C11.3 4.4 9.7 3.7 8 3.7c-3.5 0-6.3 2.8-6.3 6.3s2.8 6.3 6.3 6.3c3 0 5.4-2.1 5.4-5.4 0-.3 0-.6-.1-.9H7.5z" fill="#4285F4"/>
             <text x="16" y="15" font-family="Arial, sans-serif" font-weight="bold" font-size="13" fill="#5F6368">Pay</text>
          </svg>
        </div>
        <!-- SSL -->
        <div class="pay-ssl" title="Encriptación SSL de 256 bits">
          <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
          </svg>
          <span style="font-weight: 700; font-size: 0.8rem;">SSL 256-bit</span>
        </div>
      </div>
    </div>

    <!-- ══ BOTTOM ══ -->
    <div class="footer-btm">
      <p class="fcopy">© 2026 Hola Rentia · Software de alquiler vacacional con IA. Spreading Love &amp; Freedom ❤️</p>
      <nav class="flegal" aria-label="Navegación legal">
        <a href="/terminos-y-condiciones/">Términos</a>
        <a href="/reembolsos/">Reembolsos</a>
        <a href="/cookies/">Cookies</a>
        <a href="/aviso-legal/">Aviso Legal</a>
        <a href="/sitemap.xml">Sitemap</a>
      </nav>
    </div>

  </div>
</footer>

<style>
  footer{background:#0f172a;border-top:1px solid rgba(255,255,255,.07)}
  .f-wrap{max-width:1200px;margin:0 auto;padding:0 24px}

  /* Top grid */
  .f-top{
    display:grid;
    grid-template-columns:1.6fr 0.9fr 1fr 1.2fr;
    gap:40px;
    padding:56px 0 48px;
    border-bottom:1px solid rgba(255,255,255,.07);
  }
  .f-logo{height:56px;width:auto;display:block;margin-bottom:16px;filter:brightness(1.1)}
  .f-tagline{font-size:.82rem;color:rgba(255,255,255,.65);line-height:1.7;margin-bottom:18px;max-width:260px}
  .fchips{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:18px}
  .fchip{font-size:.65rem;color:rgba(255,255,255,.4);background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);padding:3px 9px;border-radius:50px}

  /* Socials */
  .f-socials{display:flex;gap:8px}
  .f-social{width:34px;height:34px;border-radius:8px;background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.1);display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,.5);transition:all .2s}
  .f-social:hover{background:rgba(255,59,48,.15);border-color:rgba(255,59,48,.35);color:#ff6a5a}
  .f-social svg{width:16px;height:16px}

  /* Nav columns */
  .f-col{display:flex;flex-direction:column}
  .fh{font-size:.65rem;font-weight:700;text-transform:uppercase;letter-spacing:.15em;color:rgba(255,255,255,.55);margin-bottom:14px}
  .f-links{list-style:none;display:flex;flex-direction:column;gap:9px}
  .f-links a{font-size:.82rem;color:rgba(255,255,255,.7);transition:color .18s;line-height:1.4}
  .f-links a:hover{color:#ffffff}

  /* Contact */
  .clinks{display:flex;flex-direction:column;gap:9px;margin-bottom:16px}
  .clink{display:flex;align-items:center;gap:9px;color:rgba(255,255,255,.7);font-size:.8rem;transition:color .18s}
  .clink:hover{color:#fff}
  .cico{width:28px;height:28px;background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.1);border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:.85rem;flex-shrink:0}
  .btn-fire-sm{display:inline-flex;align-items:center;gap:6px;background:linear-gradient(135deg,#ff3b30 0%,#ff6a5a 100%);color:#fff;font-size:.78rem;font-weight:700;padding:9px 18px;border-radius:50px;border:none;cursor:pointer;text-decoration:none;transition:all .22s;box-shadow:0 4px 14px rgba(255,59,48,.3)}
  .btn-fire-sm:hover{box-shadow:0 8px 24px rgba(255,59,48,.5);transform:translateY(-1px)}

  /* Payments */
  .pay-strip{padding:32px 0;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:20px;border-bottom:1px solid rgba(255,255,255,0.08)}
  .pay-label{font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.15em;color:rgba(255,255,255,.65);white-space:nowrap}
  .pay-logos{display:flex;align-items:center;gap:16px;flex-wrap:wrap}
  .pay-badge{display:flex;align-items:center;justify-content:center;height:44px;min-width:64px;padding:0 18px;border-radius:10px;background:#ffffff;border:1px solid rgba(255,255,255,0.2);transition:all .25s;box-shadow:0 4px 10px rgba(0,0,0,0.15)}
  .pay-badge:hover{transform:translateY(-3px);box-shadow:0 8px 16px rgba(0,0,0,0.25);border-color:#ff3b30}
  .pay-ssl{font-size:.8rem;color:rgba(255,255,255,.5);display:flex;align-items:center;gap:8px;margin-left:12px}

  /* Bottom */
  .footer-btm{padding:18px 0;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px}
  .fcopy{font-size:.71rem;color:rgba(255,255,255,.5)}
  .flegal{display:flex;flex-wrap:wrap;gap:14px}
  .flegal a{font-size:.71rem;color:rgba(255,255,255,.55);transition:color .18s}
  .flegal a:hover{color:rgba(255,255,255,.8)}

  @media(max-width:1024px){
    .f-top{grid-template-columns:1fr 1fr;gap:28px}
    .f-top>div:first-child{grid-column:span 2}
  }
  @media(max-width:768px){
    .f-top{grid-template-columns:1fr;pad-top:40px}
    .f-top>div:first-child{grid-column:span 1}
    .pay-strip{flex-direction:column;align-items:flex-start}
    .footer-btm{flex-direction:column;align-items:flex-start;gap:12px}
    .fchips{display:none}
  }
</style>
