---
// src/components/LegalHub.astro — Hola Rentia · Legal Country Hub Template
import Layout from '../layouts/Layout.astro';
import Footer from './Footer.astro';
import WhatsApp from './WhatsApp.astro';
export interface ArticleLink {
  title: string;
  href: string;
}

export interface FAQ {
  q: string;
  a: string;
}

export interface Props {
  country: string;
  flag: string;
  slug: string;
  metaTitle: string;
  metaDesc: string;
  canonicalUrl: string;
  intro: string;
  licensesContent: string;
  taxesContent: string;
  legalObligations: string;
  citiesContent: string;
  complianceContent: string;
  toolsContent: string;
  faq: FAQ[];
  articles: ArticleLink[];
}

const {
  country, flag, metaTitle, metaDesc, canonicalUrl, intro,
  licensesContent, taxesContent, legalObligations, citiesContent,
  complianceContent, toolsContent, faq, articles
} = Astro.props;

const schemaGraph = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://holarentia.com/#org",
      "name": "Hola Rentia",
      "url": "https://holarentia.com",
      "logo": "https://holarentia.com/images/hola-rentia-logo-gestion-airbnb-ia.webp"
    },
    {
      "@type": "WebPage",
      "@id": `${canonicalUrl}#webpage`,
      "url": canonicalUrl,
      "name": metaTitle,
      "description": metaDesc,
      "breadcrumb": { "@id": `${canonicalUrl}#breadcrumb` }
    },
    {
      "@type": "BreadcrumbList",
      "@id": `${canonicalUrl}#breadcrumb`,
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Hola Rentia", "item": "https://holarentia.com/" },
        { "@type": "ListItem", "position": 2, "name": "Recursos Legales", "item": "https://holarentia.com/es/recursos-legales" },
        { "@type": "ListItem", "position": 3, "name": country, "item": canonicalUrl }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faq.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
});
---
<Layout
  title={metaTitle}
  description={metaDesc}
  canonicalUrl={canonicalUrl}
>
  <Fragment slot="schema">
    <script type="application/ld+json" set:html={schemaGraph}/>
  </Fragment>

  <Fragment slot="head">
    <style>

  <header class="nav">
    <div class="nav-inner">
      <a href="/"><img src="/images/hola-rentia-logo-gestion-airbnb-ia.webp" alt="Hola Rentia" class="logo"/></a>
      <a href="/#formulario" class="btn" style="padding: 8px 16px; font-size: 0.8rem; margin: 0;">Analizar ahora</a>
    </div>
  </header>

  <main>
    <div class="wrap">
      <nav class="breadcrumbs">
        <a href="/">Inicio</a> <span class="sep">/</span> 
        <a href="/es/recursos-legales">Recursos Legales</a> <span class="sep">/</span>
        <span style="color:var(--text)">{country}</span>
      </nav>

      <section class="hero">
        <span style="font-size: 2.5rem; margin-bottom: 16px; display: block;">{flag}</span>
        <h1>Guía legal del alquiler vacacional en {country}</h1>
        <div class="intro" set:html={intro} />
      </section>

      <article>
        <section id="licencias">
          <h2>Licencias necesarias para alquilar en {country}</h2>
          <div set:html={licensesContent} />
        </section>

        <section id="impuestos">
          <h2>Impuestos del alquiler vacacional en {country}</h2>
          <div set:html={taxesContent} />
        </section>

        <section id="articulos">
          <h2>Guías específicas por tema</h2>
          <p>Explora nuestras guías detalladas sobre los aspectos legales más importantes del mercado vacacional en {country}.</p>
          <div class="articles-grid">
            {articles.map(art => (
              <div class="article-card">
                <h3>{art.title}</h3>
                <a href={art.href} class="read-more">Leer guía completa →</a>
              </div>
            ))}
          </div>
        </section>

        <section id="obligaciones">
          <h2>Registro de huéspedes y obligaciones legales</h2>
          <div set:html={legalObligations} />
        </section>

        <section id="ciudades">
          <h2>Principales ciudades con regulación turística</h2>
          <div set:html={citiesContent} />
        </section>

        <section id="cumplimiento">
          <h2>Cómo cumplir la normativa con varios apartamentos</h2>
          <div set:html={complianceContent} />
        </section>

        <section id="herramientas" class="content-box">
          <h2>Herramientas para gestionar legalmente</h2>
          <div set:html={toolsContent} />
          <p style="margin-top:20px;">
            <strong>HOLA RENTIA</strong> ayuda a los gestores a cumplir con las normativas locales mediante la automatización del registro de viajeros y la exportación de reportes financieros.
          </p>
        </section>

        <div class="cta">
          <h2>Gestiona tus alquileres en {country} cumpliendo la ley</h2>
          <p>Automatiza el registro de huéspedes y quédate con el 100% de tus ingresos. Sin comisiones.</p>
          <a href="/#formulario" class="btn">Empieza Gratis Ahora</a>
        </div>
      </article>
    </div>
  </main>

  <WhatsApp />
  <Footer />

</Layout>
